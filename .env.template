# LDAP module .env template. The installer writes the real .env; connection
# settings are normally PUSHED by the hub via UPDATE_CONFIG (hub = source of truth).
SPOKE_ID=ldap-spoke-1
SPOKE_SECRET=change-me
HUB_SECRET=change-me
HUB_URL=auto

# ── Directory connection (shared contract) ──────────────────────────────────
LDAP_BASE_DN="dc=lm,dc=local"
LDAP_ADMIN_DN="cn=admin,dc=lm,dc=local"
LDAP_ADMIN_PW="change-me"
LDAP_SERVER_URL="ldap://localhost:389"

# ── 2-node syncrepl mirror-mode ─────────────────────────────────────────────
# LDAP_SERVER_ID: this node's id (1 or 2). LDAP_MIRROR_PEERS: JSON list of peer
# ldap(s):// URLs, e.g. ["ldaps://ldap2.lm.local:636"].
LDAP_SERVER_ID=
LDAP_MIRROR_PEERS=

# ── Entra ID ROPC pass-through (cert-based confidential client) ──────────────
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_CERT=
ENTRA_CLIENT_KEY=
ENTRA_ROPC_SCOPE=openid
